# Application Configuration
DEBUG=False
TESTING=False

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=wellness_logging

# API Configuration
API_HOST=127.0.0.1
API_PORT=5000

# Feature Flags
ENABLE_CLINICAL_VALIDATION=True
